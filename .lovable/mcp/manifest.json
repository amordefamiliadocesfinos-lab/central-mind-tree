    "type": "oauth",
    "issuer": "https://xkskyutmtlhivvpfxkjg.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "painel-central-mcp",
      "version": "0.1.0",
      "title": "Painel Central – Cérebro"
    },
    "tools": [
      {
        "name": "list_contacts",
        "title": "Listar contatos",
        "description": "Lista contatos do CRM. Suporta busca por nome/email/telefone e filtro por estágio do funil.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Texto para buscar em nome, email, telefone ou WhatsApp."
            },
            "funnel_status": {
              "type": "string",
              "description": "Filtra por estágio do funil (ex.: novo_lead, qualificado, cliente_ativo, vip)."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Máximo de resultados (padrão 25)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_contact",
        "title": "Detalhes do contato",
        "description": "Retorna dados completos de um contato, seus pedidos recentes e histórico recente.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "contact_id": {
              "type": "string",
              "format": "uuid",
              "description": "ID do contato."
            }
          },
          "required": [
            "contact_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_orders",
        "title": "Listar pedidos",
        "description": "Lista pedidos com filtros opcionais por status, contato e intervalo de datas.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "Ex.: pendente, em_producao, entregue, cancelado."
            },
            "contact_id": {
              "type": "string",
              "format": "uuid"
            },
            "from_date": {
              "type": "string",
              "description": "Data mínima YYYY-MM-DD (order_date)."
            },
            "to_date": {
              "type": "string",
              "description": "Data máxima YYYY-MM-DD (order_date)."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_tasks",
        "title": "Listar tarefas",
        "description": "Lista tarefas com filtros por status, contato e datas (scheduled_date).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "Ex.: pendente, em_andamento, concluida, on_hold."
            },
            "contact_id": {
              "type": "string",
              "format": "uuid"
            },
            "from_date": {
              "type": "string",
              "description": "Data mínima YYYY-MM-DD."
            },
            "to_date": {
              "type": "string",
              "description": "Data máxima YYYY-MM-DD."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_task",
        "title": "Criar tarefa",
        "description": "Cria uma nova tarefa no Painel Central. Sempre vinculada ao nó raiz por padrão.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1,
              "description": "Título da tarefa."
            },
            "scheduled_date": {
              "type": "string",
              "description": "Data agendada YYYY-MM-DD."
            },
            "scheduled_time": {
              "type": "string",
              "description": "Hora HH:MM."
            },
            "due_date": {
              "type": "string",
              "description": "Prazo YYYY-MM-DD."
            },
            "contact_id": {
              "type": "string",
              "format": "uuid",
              "description": "Contato relacionado (opcional)."
            },
            "node_id": {
              "type": "string",
              "format": "uuid",
              "description": "Nó do organograma (padrão: raiz Deividi)."
            },
            "assigned_to": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "title"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "financial_summary",
        "title": "Resumo financeiro",
        "description": "Retorna totais a receber e a pagar (abertos e pagos) em um intervalo de datas de vencimento.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "from_date": {
              "type": "string",
              "description": "Data inicial YYYY-MM-DD (due_date)."
            },
            "to_date": {
              "type": "string",
              "description": "Data final YYYY-MM-DD (due_date)."
            }
          },
          "required": [
            "from_date",
            "to_date"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
